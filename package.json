{
  "name": "lecture-processor-e2e",
  "private": true,
  "version": "1.0.0",
  "description": "Optional Playwright end-to-end smoke checks for Lecture Processor",
  "scripts": {
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "test:client-goals": "node --test tests_js/*.test.js",
    "build:assets": "node scripts/build_assets.mjs",
    "check:assets": "node scripts/build_assets.mjs --check"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "esbuild": "0.27.3"
  }
}
